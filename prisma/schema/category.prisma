model Category {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties    Property[]
  createdByUser User       @relation(fields: [createdBy], references: [id])

  @@map("categories")
}
