model User {
    id           String     @id @default(uuid())
    name         String     @db.VarChar(255)
    email        String     @unique
    password     String
    phone        String     @db.VarChar(20)
    activeStatus UserStatus @default(ACTIVE)
    role         Role       @default(TENANT)
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt

    property Property[]

    @@map("users")
}
